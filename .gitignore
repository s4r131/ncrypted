**/ios/**/*.xcworkspace/xcshareddata/WorkspaceSettings.xcsettings
**/ios/**/Flutter/Flutter.framework
**/ios/**/Flutter/Flutter.podspec
**/ios/**/Flutter/Generated.xcconfig
**/ios/**/Flutter/ephemeral/
**/ios/**/Pods/

# Android/Java
**/android/**/gradle-wrapper.jar
**/android/.gradle
**/android/captures/
**/android/gradlew
**/android/gradlew.bat
**/android/local.properties
**/android/**/GeneratedPluginRegistrant.java

# Coverage
coverage/

# Design/Documentation (not required for deployment)
ncrypt_design_system.html
ncrypt_flutter_blueprint.html
ncrypt_logo_variants.html
ncrypt_logo_final.svg

# Exceptions to above rules.
!**/ios/**/default.*
!**/macos/**/default.*
